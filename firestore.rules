rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()   { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function userRole() {
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(uid())).data.get('role','reader')
        : 'reader';
    }
    function isAdmin() { return userRole() == 'admin'; }
    function isCTV()   { return userRole() == 'ctv' || isAdmin(); }

    // Users
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && (uid() == userId || isAdmin());
      allow update: if isAuth() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
      match /unlocked/{docId} {
        allow read, write: if isAuth() && uid() == userId;
      }
    }

    // Stories — public read
    match /stories/{storyId} {
      allow read:   if true;
      allow create: if isCTV();
      allow update: if isCTV();
      allow delete: if isAdmin();
      match /chapters/{chapterId} {
        allow read:  if true;
        allow write: if isCTV();
        match /comments/{commentId} {
          allow read:   if true;
          allow create: if isAuth() && request.resource.data.uid == uid();
          allow delete: if isAdmin() || (isAuth() && resource.data.uid == uid());
          allow update: if isAdmin();
        }
      }
    }

    // CMS — pages, posts, notifications (admin only write, public read)
    match /pages/{pageId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /notifications/{nId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Affiliate
    match /affiliateClicks/{docId} {
      allow read:  if isAdmin();
      allow create: if true;
    }
    match /affiliateProducts/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // CTV Applications & Payments
    match /ctvApplications/{docId} {
      allow read:  if isAdmin() || (isAuth() && resource.data.userId == uid());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /payments/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }
  }
}
